# App
SECRET_KEY=change-me-to-a-random-string
DEBUG=true

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/conexperiment
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@localhost:5432/conexperiment

# Redis
REDIS_URL=redis://localhost:6379/0

# LLM (primary)
OPENAI_API_KEY=sk-xxx
ANTHROPIC_API_KEY=

# LLM (backup / fallback provider — optional)
LLM_BACKUP_API_BASE=
LLM_BACKUP_API_KEY=
LLM_BACKUP_MODEL=gpt-4o-mini

# Encryption (for Prolific IDs at rest)
ENCRYPTION_KEY=generate-with-python-cryptography-Fernet

# Admin
ADMIN_PASSWORD_HASH=generate-with-bcrypt-or-argon2

# Prolific
PROLIFIC_COMPLETION_URL=
PROLIFIC_API_TOKEN=

# Demo Mode (for testing and presentations)
# Set to true to reduce turns/timeouts and skip Prolific checks
DEMO_MODE=false
